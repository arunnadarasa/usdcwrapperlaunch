# RPC + deployer
RPC_URL="https://base-sepolia-rpc.example"
PRIVATE_KEY="0xYOUR_PRIVATE_KEY"

# Base Sepolia USDC
USDC_ADDRESS="0x036CbD53842c5426634e7929541eC2318f3dCF7e"

# Verification (BaseScan)
ETHERSCAN_API_KEY="YOUR_BASESCAN_API_KEY"

# Token launch parameters
# Example suffixes: Krump, IKF, ...
SUFFIX="Krump"
INITIAL_USDC_AMOUNT="1000000" # USDC smallest units (6 decimals)
RECIPIENT="0xYourRecipientAddress"

# Optional: if you already deployed the factory, set it here
# FACTORY_ADDRESS="0xYourFactoryAddress"

